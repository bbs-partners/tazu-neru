# LINE WORKS API
LINEWORKS_CLIENT_ID=
LINEWORKS_CLIENT_SECRET=
LINEWORKS_SERVICE_ACCOUNT=
LINEWORKS_PRIVATE_KEY=
LINEWORKS_BOT_ID=
LINEWORKS_BOT_SECRET=

# LLM プロバイダー設定
# LLM_PROVIDER: anthropic / openai / google
LLM_PROVIDER=anthropic
# LLM_MODEL: 省略時はプロバイダーごとのデフォルト
# anthropic → claude-sonnet-4-6 / openai → gpt-4o / google → gemini-2.0-flash
# LLM_MODEL=

# プロバイダーごとの API キー（使用するものだけ設定）
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
